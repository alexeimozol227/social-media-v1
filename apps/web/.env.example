# ===== social-media-v1 — frontend (Next.js) .env.example =====
# Скопируй файл в `.env.local` и поправь значения под себя.
# Все переменные с префиксом NEXT_PUBLIC_ попадают в бандл
# браузера — не клади сюда секретов.

# Базовый URL бэкенд-API. На него фронт уходит за всеми
# `/v1/...` ручками. В dev — локальный uvicorn на 8000.
# В проде указать HTTPS-домен публичного API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
