{# English variant of the base HTML layout — same structure as the
   RU version, only the header tagline and footer copy are localised.
   See the RU file for design rationale.
-#}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block subject %}{{ product_name }}{% endblock %}</title>
</head>
<body style="margin:0;padding:0;background-color:#eef0f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,sans-serif;color:#0f172a;-webkit-font-smoothing:antialiased;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color:#eef0f5;padding:40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width:560px;background-color:#ffffff;border-radius:16px;border:1px solid #e6e7ef;box-shadow:0 8px 24px rgba(15,23,42,0.06);overflow:hidden;">

          {# Header — brand bar with logo badge + wordmark #}
          <tr>
            <td style="background-color:#5b4ef0;padding:24px 32px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="vertical-align:middle;padding-right:12px;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="40" height="40" style="width:40px;height:40px;background-color:#ffffff;border-radius:11px;">
                      <tr>
                        <td align="center" style="font-size:20px;font-weight:700;color:#5b4ef0;line-height:40px;">S</td>
                      </tr>
                    </table>
                  </td>
                  <td style="vertical-align:middle;">
                    <div style="color:#ffffff;font-size:17px;font-weight:700;letter-spacing:0.2px;">{{ product_name }}</div>
                    <div style="color:rgba(255,255,255,0.78);font-size:12px;margin-top:2px;">AI team for social networks</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          {# Body card #}
          <tr>
            <td style="padding:36px 32px;">
              <h1 style="margin:0 0 18px 0;font-size:22px;font-weight:700;line-height:1.3;color:#0f172a;letter-spacing:-0.2px;">
                {% block title %}{% endblock %}
              </h1>
              <div style="font-size:15px;line-height:1.6;color:#334155;">
                {% block content %}{% endblock %}
              </div>
            </td>
          </tr>

          {# Footer #}
          <tr>
            <td style="background-color:#f7f7fb;padding:24px 32px;border-top:1px solid #ececf2;">
              <p style="margin:0 0 6px 0;font-size:13px;font-weight:600;color:#475569;">
                {{ product_name }}
              </p>
              <p style="margin:0 0 12px 0;font-size:12px;line-height:1.5;color:#94a3b8;">
                AI operating system for social networks.
              </p>
              <p style="margin:0;font-size:12px;line-height:1.5;color:#94a3b8;">
                © {{ year }} {{ product_name }}. This is an automated message — please don't reply.
                For questions, reach support via your account settings.
              </p>
            </td>
          </tr>
        </table>

        <p style="margin:20px 0 0 0;font-size:11px;color:#aab2c0;">
          {{ product_name }}
        </p>
      </td>
    </tr>
  </table>
</body>
</html>
