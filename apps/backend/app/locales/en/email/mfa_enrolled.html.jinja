{% extends "email/_base.html.jinja" %}
{% block title %}Two-factor authentication enabled{% endblock %}
{% block content %}
<p style="margin:0 0 16px 0;">Hi there,</p>
<p style="margin:0 0 16px 0;">
  Two-factor authentication (2FA) was just enabled on your {{ product_name }} account.
  From now on, signing in requires a code from your authenticator app in addition
  to your password.
</p>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:16px 0 24px 0;background-color:#fef3c7;border:1px solid #fde68a;border-radius:8px;">
  <tr>
    <td style="padding:16px 20px;color:#92400e;font-size:14px;line-height:1.5;">
      <strong>If this wasn't you</strong>, change your password immediately and
      disable 2FA from Security settings.
    </td>
  </tr>
</table>
<p style="margin:0;color:#475569;font-size:13px;">
  Save the recovery codes you got when enabling 2FA somewhere safe — you'll need them
  if you lose access to your authenticator app.
</p>
{% endblock %}
