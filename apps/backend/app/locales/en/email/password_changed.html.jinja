{% extends "email/_base.html.jinja" %}
{% block title %}Password changed{% endblock %}
{% block content %}
<p style="margin:0 0 16px 0;">Hi there,</p>
<p style="margin:0 0 16px 0;">
  Your {{ product_name }} account password was just changed from account settings.
  All active sessions have been signed out — sign back in with your new password.
</p>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:16px 0 24px 0;background-color:#fef3c7;border:1px solid #fde68a;border-radius:8px;">
  <tr>
    <td style="padding:16px 20px;color:#92400e;font-size:14px;line-height:1.5;">
      <strong>If this wasn't you</strong>, contact support from the account
      settings page. We'll revoke active sessions and run a fresh password reset.
    </td>
  </tr>
</table>
<p style="margin:0;color:#475569;font-size:13px;">
  If this was you — no action needed, keep using the service.
</p>
{% endblock %}
