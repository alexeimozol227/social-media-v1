{% extends "email/_base.html.jinja" %}
{% block title %}Подтверди новый email{% endblock %}
{% block content %}
<p style="margin:0 0 16px 0;">Привет!</p>
<p style="margin:0 0 16px 0;">
  Введи этот код в окне смены email в {{ product_name }}. Он действует
  <strong>{{ ttl_minutes }} минут</strong>. Старый email остаётся активным,
  пока новый не подтверждён.
</p>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center" style="margin:24px auto;">
  <tr>
    <td style="background-color:#eef2ff;border:1px solid #c7d2fe;border-radius:8px;padding:16px 28px;font-family:'SFMono-Regular',Menlo,Consolas,'Liberation Mono',monospace;font-size:28px;letter-spacing:6px;font-weight:600;color:#3730a3;">
      {{ code }}
    </td>
  </tr>
</table>
<p style="margin:0;color:#475569;font-size:13px;">
  Если ты не запрашивал(а) смену email, измени пароль в настройках аккаунта —
  возможно, кто-то получил доступ к твоему профилю.
</p>
{% endblock %}
