# ===== social-media-v1 — backend .env.example =====
# Все переменные окружения, которые читает бэкенд. Скопируй файл в
# `.env` и поправь значения под себя. Источник истины по полям —
# `app/core/config.py` (`class Settings`).
#
# Комментарии оставлены русскоязычными, чтобы новичкам в команде
# было проще читать. Реальные значения секретов в этот файл класть
# нельзя — для прод-среды используется vault / переменные CI.

# ----- Postgres -----
# Логин/пароль/имя БД для локального docker-compose. Все три
# подставляются в строку подключения ниже, в проде они приходят
# отдельно.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_media_dev

# Основная строка подключения к Postgres через asyncpg. На неё
# смотрят миграции (Alembic) и dev-сервер. Драйвер обязан быть
# именно `postgresql+asyncpg://` — синхронный psycopg2 не сработает.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/social_media_dev

# PR #11 / docs/04-architecture.md §18.7: «прод-подобная» строка
# подключения через PgBouncer в режиме `pool_mode=transaction`.
# Боевые API-воркеры ходят сюда; миграции и `alembic upgrade head`
# ОБЯЗАНЫ ходить напрямую в 5432 (Alembic держит session-level
# advisory-локи, которые transaction-режим PgBouncer-а отбрасывает).
DATABASE_URL_POOLED=postgresql+asyncpg://postgres:postgres@localhost:6432/social_media_dev

# ----- Redis -----
# Используется под login-lockout, кэш фич-флагов, idempotency-ключи
# и pub/sub event bus. Брокер Celery вынесен в отдельную логическую
# БД (см. CELERY_BROKER_URL ниже).
REDIS_URL=redis://localhost:6379/0

# ----- API -----
# `development` | `staging` | `production`. От значения зависят
# secure-cookie, обязательность Fernet-ключей и т.д.
ENVIRONMENT=development
# Уровень логирования (`DEBUG`/`INFO`/`WARNING`/`ERROR`).
LOG_LEVEL=INFO
# Адрес и порт, на которых поднимается uvicorn. В docker-compose
# контейнер слушает 0.0.0.0:8000, а наружу прокидывается через
# nginx/Traefik.
API_HOST=0.0.0.0
API_PORT=8000
# Публичный URL API — попадает в ссылки в письмах и в OpenAPI.
API_BASE_URL=http://localhost:8000
# Публичный URL фронта — на этот домен ведут ссылки из писем
# (password reset и т.п.), а также используется как `Origin` в CORS.
WEB_BASE_URL=http://localhost:3000

# Секрет для подписи JWT. В проде должен быть минимум 32 случайных
# байта. Сгенерировать можно так:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-locally-please-use-secrets-token-urlsafe-48-in-prod
# Алгоритм подписи JWT. Не меняй без необходимости — крутим
# HS256, согласован с фронтом и тестами.
ALGORITHM=HS256
# Сроки жизни токенов. Access короткий (минуты), refresh длинный
# (дни). 15 мин / 30 дн — стандарт из docs/06-roadmap §5 Спринт 1.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Разрешённые Origin-ы для CORS, через запятую. В dev — только
# фронт на :3000. В проде сюда добавляется домен админки.
CORS_ORIGINS=http://localhost:3000

# ----- Политика блокировки логина -----
# Идея: защита от credential stuffing. Лок ведём по email, а не
# по IP, чтобы атакующему за NAT-ом не получалось «выбить»
# легитимного пользователя.
# Порог попыток за окно, окно (сек) и длительность лока (сек).
LOGIN_LOCK_THRESHOLD=10
LOGIN_LOCK_WINDOW_SECONDS=1800
LOGIN_LOCK_DURATION_SECONDS=1800

# ----- Sentry (опционально) -----
# Пустая строка = трекинг отключён. В dev/CI оставляем пустым.
SENTRY_DSN=

# ----- Транспорт email -----
# Порядок выбора реализации (см. `app/core/email.py`):
#   1) UniSender Go (если задан UNISENDER_API_KEY) — прод.
#   2) SMTP (если задан SMTP_HOST) — локалка через MailHog.
#   3) LogEmailSender — fallback для dev/CI, ничего не отправляет,
#      пишет письмо в лог. Используется по умолчанию.

# SMTP для локальной отладки. Контейнер `mailhog` из
# docker-compose.yml слушает 1025 (SMTP) и 8025 (web UI).
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@social-media-v1.local
# `true` — обернуть соединение в TLS (нужно для боевых SMTP-релеев).
SMTP_TLS=false

# UniSender Go — боевой провайдер. Пустые значения = выключен.
UNISENDER_API_KEY=
UNISENDER_API_URL=https://go1.unisender.ru/ru/transactional/api/v1
UNISENDER_FROM_EMAIL=no-reply@social-media-v1.local
UNISENDER_FROM_NAME=social-media-v1

# ----- Политика подтверждения email -----
# TTL кода (мин), cooldown перед повторной отправкой (сек),
# максимум попыток ввода до принудительного «consume» строки.
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# ----- Политика сброса пароля -----
# TTL одноразовой ссылки (мин) и cooldown на повторный запрос (сек).
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60

# ----- MFA / TOTP -----
# Fernet-ключи для шифрования TOTP-секрета пользователя в БД.
# Каждый ключ — urlsafe-base64 32 байта. Сгенерировать можно так:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# В dev/CI оставляем пустыми — приложение детерминированно выводит
# ключ из SECRET_KEY, чтобы тесты не требовали реальных значений.
# В проде SECRET_KEY_FERNET_V1 обязателен; V2 задаётся заранее,
# чтобы ротировать ключи без перешифровки старых строк (префикс
# `v1:` / `v2:` в зашифрованном поле направляет дешифратор к
# нужному ключу).
SECRET_KEY_FERNET_V1=
SECRET_KEY_FERNET_V2=

# Issuer-метка в приложении аутентификатора (видна в Google
# Authenticator / 1Password рядом с email пользователя). Держим
# равной продовому хосту, чтобы аккаунты разных стендов не
# путались.
TOTP_ISSUER=social-media-v1

# Время жизни «черновика» enrollment-сессии в Redis между
# `/mfa/enroll/start` (показали QR) и `/mfa/enroll/confirm`
# (ввели код).
MFA_ENROLL_TTL_SECONDS=300

# Время жизни короткоживущего mfa_token JWT, который `/v1/auth/login`
# возвращает аккаунтам с 2FA. SPA меняет его на cookie через
# `/v1/auth/login/mfa`.
MFA_TOKEN_TTL_SECONDS=300

# Rate-limit на `/v1/auth/login/mfa` (брутфорс 6-значного кода).
# Счётчик per-jti, поэтому новый login сбрасывает попытки.
MFA_LOGIN_RATE_LIMIT_ATTEMPTS=5
MFA_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Сколько одноразовых recovery-кодов выдаём при включении 2FA
# и при «перевыдаче».
MFA_RECOVERY_CODE_COUNT=10

# ----- Фич-флаги / Unleash (PR #8, D42 в docs/04) -----
# Если UNLEASH_URL пуст, приложение использует in-memory map с
# дефолтами, и поднимать Unleash локально не нужно.
UNLEASH_URL=
UNLEASH_API_KEY=
UNLEASH_APP_NAME=social-media-v1
UNLEASH_INSTANCE_ID=dev
UNLEASH_REFRESH_INTERVAL=15

# ----- Idempotency middleware (PR #8, П13 в docs/04) -----
# TTL идемпотентных ключей в Redis. Дефолт — 24 ч (86400 с),
# совпадает с docs/05 §2.5.
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# ----- OpenTelemetry (PR #9, docs/04 §15, docs/05 §10.2) -----
# Пустое значение = no-op трейсинг, ничего не отправляем.
# Для прода указать OTLP-эндпоинт Tempo/Jaeger/Grafana, например:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=social-media-v1-api

# ----- Telegram Bot API (PR #14, docs/plans/phase1-sprint2-plan.md) -----
# Боевой токен бота от @BotFather. В dev/CI пусто — адаптер
# подцепит `MockTelegramBotClient`, и юнит-тестам реальный токен
# не нужен.
TELEGRAM_BOT_TOKEN=

# Отдельный токен для dev/staging бота, чтобы локальная
# разработка не дёргала вебхук продового бота.
TELEGRAM_BOT_TOKEN_DEV=

# Публичный @username бота (например, `social_media_v1_bot`).
# Используется в connect-wizard на фронте, чтобы подсказать
# пользователю «добавь @<bot> админом».
TELEGRAM_BOT_USERNAME=

# ----- Бэкфилл истории каналов (PR #15, docs/plans/phase1-sprint2-plan.md) -----
# Дефолт окна на один вызов и абсолютный потолок.
# При превышении API возвращает 422 CHANNEL_BACKFILL_LIMIT_EXCEEDED.
TELEGRAM_BACKFILL_DEFAULT_LIMIT=100
TELEGRAM_BACKFILL_MAX_LIMIT=500

# ----- Live-вебхук Telegram (PR #16, docs/plans/phase1-sprint2-plan.md) -----
# Хендлер сверяет заголовок `X-Telegram-Bot-API-Secret-Token` с
# TELEGRAM_WEBHOOK_SECRET через `hmac.compare_digest`. Несовпадение
# или пустой секрет → 401 TELEGRAM_WEBHOOK_UNAUTHORIZED.
# Путь конфигурируем, чтобы dev/staging/prod-боты могли делить
# один и тот же бинарь, но каждый указывал TG на свой роут.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/v1/integrations/telegram/webhook

# ----- Celery (PR #15, docs/05-tech-stack.md §2.4) -----
# Redis переиспользуется как брокер + result backend; логические
# БД 1 и 2 изолируют очередь от pub/sub event-bus на БД 0.
# Воркер поднимается через `make dev-worker` или сервис
# `celery-worker` из docker-compose (`--profile workers`).
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Лимиты времени задачи (сек). 500 постов на ~1 запрос/сек к Bot
# API укладываются в 240/300 с с запасом.
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300

# `true` — `.delay()` выполняется синхронно прямо в процессе.
# Используется в e2e-тестах; в проде ВСЕГДА `false`.
CELERY_TASK_ALWAYS_EAGER=false

# ----- LLM / embeddings (PR #17 + PR #20, docs/plans/phase1-sprint{2,3}-plan.md) -----
# `llm_provider` выбирает конкретный класс `LLMProvider` при
# старте. `mock` — детерминированные сидованные векторы без сети,
# дефолт для dev/CI. `polza` — реальный gateway (Sprint 3, PR #20).
LLM_PROVIDER=mock
# Ключ Polza API. Используется только при LLM_PROVIDER=polza.
POLZA_API_KEY=
# Эндпоинт Polza API. Меняется только при тестировании.
POLZA_BASE_URL=https://api.polza.ai/api/v1
# Таймаут (сек) на один HTTP-вызов к Polza. По умолчанию 30 с — между
# embed-эндпоинтом (доли секунды) и chat-эндпоинтом (десятки секунд).
LLM_GATEWAY_TIMEOUT_SECONDS=30.0
# Бюджет повторов tenacity. ``max_attempts=3`` = первая попытка плюс
# до двух retry; backoff экспоненциальный c джиттером в указанных
# границах.
LLM_GATEWAY_RETRY_MAX_ATTEMPTS=3
LLM_GATEWAY_RETRY_INITIAL_BACKOFF_SECONDS=0.5
LLM_GATEWAY_RETRY_MAX_BACKOFF_SECONDS=8.0
# Параметры circuit breaker (pybreaker, состояние в Redis). После
# ``fail_threshold`` подряд ошибок ставим OPEN на ``reset_seconds``,
# затем HALF_OPEN с одной пробной попыткой.
LLM_CIRCUIT_BREAKER_FAIL_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RESET_SECONDS=60
# Кеш ответов в Redis (TTL, сек). ``0`` — кеш отключён. Ключ —
# хэш ``(provider, model, messages, tools, response_format)``.
LLM_PROMPT_CACHE_TTL_SECONDS=0
# Курс USD→RUB при отсутствии ``fx_rates``-снэпшота. План фиксирует
# 95 RUB / USD как разумный дефолт для dev/CI.
USD_TO_RUB_FALLBACK=95.0
# Модель эмбеддингов и её размерность. По умолчанию
# `text-embedding-3-small` (1536 dim) — выбор из docs/05 §3.
# Менять оба поля синхронно, иначе HNSW-индекс не сойдётся.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Дефолтное значение ``users.opt_in_training`` для новых аккаунтов
# (D58, docs/04 §18.5). По умолчанию ``false`` — пользователь сам
# включает «использовать мои данные для обучения» в настройках.
DEFAULT_OPT_IN_TRAINING=false

# ----- User-bot / Pyrogram pool (PR #18, docs/05 §5.2, D40) -----
# Fernet-ключ для шифрования сессионных credentials юзер-ботов
# в БД. Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# В dev/CI оставляем пустым — модуль `userbot.crypto` упадёт с
# понятной ошибкой, если его реально позовут без ключа.
USERBOT_ENCRYPTION_KEY=
# `mock` — детерминированные фикстуры; `pyrogram` — реальная
# MTProto-сессия (Sprint 3). Та же логика, что у LLM_PROVIDER.
USERBOT_CLIENT=mock
# Мягкий rate-limit: сессии с usage>лимит пул деприоритизирует
# при выборе. Жёсткий ресет — pg_cron job в Sprint 8.
USERBOT_MAX_USAGE_PER_24H=1000
# Сколько минут держать сессию в статусе flood_wait после
# Telegram FloodWait. Запрос пула пропускает сессии с
# `flood_wait_until > now()`.
USERBOT_FLOOD_WAIT_COOLDOWN_MINUTES=60
