# ----- Postgres -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_media_dev

# Backend reads ``DATABASE_URL`` directly (asyncpg).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/social_media_dev

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- API -----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# Must be at least 32 random bytes in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-locally-please-use-secrets-token-urlsafe-48-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=http://localhost:3000

# ----- Lockout policy -----
LOGIN_LOCK_THRESHOLD=10
LOGIN_LOCK_WINDOW_SECONDS=1800
LOGIN_LOCK_DURATION_SECONDS=1800

# ----- Sentry (optional) -----
SENTRY_DSN=

# ----- Email transport -----
# Resolution order: UniSender Go > SMTP > LogEmailSender (default for dev/CI).

# SMTP (e.g. MailHog at localhost:1025 — uses the docker-compose service).
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@social-media-v1.local
SMTP_TLS=false

# UniSender Go (production). Empty = disabled.
UNISENDER_API_KEY=
UNISENDER_API_URL=https://go1.unisender.ru/ru/transactional/api/v1
UNISENDER_FROM_EMAIL=no-reply@social-media-v1.local
UNISENDER_FROM_NAME=social-media-v1

# ----- Email verification policy -----
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# ----- Password reset policy -----
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60
