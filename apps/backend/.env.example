# ----- Postgres -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_media_dev

# Backend reads ``DATABASE_URL`` directly (asyncpg).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/social_media_dev

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- API -----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# Must be at least 32 random bytes in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-locally-please-use-secrets-token-urlsafe-48-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=http://localhost:3000

# ----- Lockout policy -----
LOGIN_LOCK_THRESHOLD=10
LOGIN_LOCK_WINDOW_SECONDS=1800
LOGIN_LOCK_DURATION_SECONDS=1800

# ----- Sentry (optional) -----
SENTRY_DSN=

# ----- Email transport -----
# Resolution order: UniSender Go > SMTP > LogEmailSender (default for dev/CI).

# SMTP (e.g. MailHog at localhost:1025 — uses the docker-compose service).
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@social-media-v1.local
SMTP_TLS=false

# UniSender Go (production). Empty = disabled.
UNISENDER_API_KEY=
UNISENDER_API_URL=https://go1.unisender.ru/ru/transactional/api/v1
UNISENDER_FROM_EMAIL=no-reply@social-media-v1.local
UNISENDER_FROM_NAME=social-media-v1

# ----- Email verification policy -----
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# ----- Password reset policy -----
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_COOLDOWN_SECONDS=60

# ----- MFA / TOTP policy (PR #4) -----
# Fernet keys for encrypting the TOTP shared secret at rest.
# Each value must be a urlsafe-base64-encoded 32-byte key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in dev/CI: the app derives a deterministic key from
# SECRET_KEY so tests don't need to set anything. Production MUST set
# at least SECRET_KEY_FERNET_V1; set V2 ahead of time to rotate keys
# without re-encrypting existing rows (the v1: / v2: prefix on each
# ciphertext column points the decrypt path at the right key).
SECRET_KEY_FERNET_V1=
SECRET_KEY_FERNET_V2=

# Issuer label shown in the authenticator app (the "Account" row
# of the QR). Keep this aligned with the production hostname so
# users with multiple accounts can tell them apart.
TOTP_ISSUER=social-media-v1

# How long the pending enrollment secret lives in Redis between
# /mfa/enroll/start (QR shown) and /mfa/enroll/confirm.
MFA_ENROLL_TTL_SECONDS=300

# TTL of the short-lived mfa_token JWT returned by /v1/auth/login
# when the account has 2FA on. The SPA exchanges it via
# /v1/auth/login/mfa for normal session cookies.
MFA_TOKEN_TTL_SECONDS=300

# Rate-limit on /v1/auth/login/mfa (bounded brute force on the
# 6-digit code). Counter is per-jti so a fresh login resets it.
MFA_LOGIN_RATE_LIMIT_ATTEMPTS=5
MFA_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Number of one-shot recovery codes minted on enrollment / regenerate.
MFA_RECOVERY_CODE_COUNT=10

# ----- Feature flags / Unleash (PR #8, D42 in docs/04) -----
# When UNLEASH_URL is empty the app falls back to an in-memory default
# map, so local dev / CI don't require a running Unleash server.
UNLEASH_URL=
UNLEASH_API_KEY=
UNLEASH_APP_NAME=social-media-v1
UNLEASH_INSTANCE_ID=dev
UNLEASH_REFRESH_INTERVAL=15

# ----- Idempotency middleware (PR #8, П13 in docs/04) -----
# TTL for idempotency keys stored in Redis. Default = 24 h (86400 s).
IDEMPOTENCY_KEY_TTL_SECONDS=86400
